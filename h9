                                        <path id="gauge-path" d="M 10 100 A 90 90 0 0 1 190 100" fill="none" stroke="url(#gaugeGradient)" stroke-width="12" stroke-linecap="round" stroke-dasharray="283" stroke-dashoffset="283"/>
                                    </svg>
                                </div>
                                <div class="gauge-value" id="risk-score">0</div>
