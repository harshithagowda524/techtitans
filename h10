        function displayResult(result) {
            const riskScoreEl = document.getElementById('risk-score');
            const resultStatus = document.getElementById('result-status');
            const confidenceFill = document.getElementById('confidence-fill');
            const confidenceValue = document.getElementById('confidence-value');
            const indicatorsList = document.getElementById('indicators-list');
            const timelineItems = document.getElementById('timeline-items');
            const recommendations = document.getElementById('recommendations');
            const gaugePath = document.getElementById('gauge-path');

            let score = 0;
            const targetScore = result.riskScore;
            const duration = 30;
            const interval = setInterval(() => {
                score++;
                const progress = score / 100;
                const dashOffset = 283 * (1 - progress);
                gaugePath.style.strokeDashoffset = dashOffset;

                if (score < 40) {
                    riskScoreEl.className = 'gauge-value risk-low';
                } else if (score < 70) {
                    riskScoreEl.className = 'gauge-value risk-medium';
                } else {
                    riskScoreEl.className = 'gauge-value risk-high';
                }

                riskScoreEl.textContent = score;
                if (score >= targetScore) clearInterval(interval);
            }, duration);

            confidenceValue.textContent = result.confidence + '%';
            confidenceFill.style.width = result.confidence + '%';
            
            resultStatus.textContent = result.recommendation.toUpperCase();
            resultStatus.className = 'result-status status-' + result.recommendation;

            indicatorsList.innerHTML = '';
            if (result.indicators.length === 0) {
                indicatorsList.innerHTML = '<li class="indicator-item"><span class="indicator-severity">No threats detected</span>Content appears safe</li>';
            } else {
                result.indicators.forEach((ind, i) => {
