        // ======================= BLOCKCHAIN =======================
        class Block {
            constructor(index, timestamp, data, previousHash, nonce = 0) {
                this.index = index;
                this.timestamp = timestamp;
                this.data = data;
                this.previousHash = previousHash;
                this.nonce = nonce;
                this.hash = this.computeHash();
            }

            computeHash() {
                const str = `${this.index}${this.timestamp}${JSON.stringify(this.data)}${this.previousHash}${this.nonce}`;
                let hash = 0;
                for (let i = 0; i < str.length; i++) {
                    const char = str.charCodeAt(i);
                    hash = ((hash << 5) - hash) + char;
                    hash = hash & hash;
                }
                return Math.abs(hash).toString(16).padStart(64, '0').substring(0, 64);
            }

            mineBlock(difficulty) {
                const target = '0'.repeat(difficulty);
                while (this.hash.substring(0, difficulty) !== target) {
                    this.nonce++;
                    this.hash = this.computeHash();
                }
            }
        }

        class Blockchain {
            constructor() {
                this.chain = [];
                this.difficulty = 2;
                this.validators = ['node-alpha', 'node-beta', 'node-gamma', 'node-delta', 'node-epsilon'];
                this.pendingTransactions = [];
                this.createGenesisBlock();
            }

            createGenesisBlock() {
                const genesisData = {
                    type: 'genesis',
                    message: 'PhishChain Pro Threat Ledger Initialized',
                    network: 'PhishChain Pro v2.0',
                    consensus: 'Proof of Authority'
                };
                this.chain.push(new Block(0, new Date().toISOString(), genesisData, '0'.repeat(64)));
            }

            addBlock(threatData) {
                const lastBlock = this.chain[this.chain.length - 1];
                const newIndex = this.chain.length;
                const timestamp = new Date().toISOString();
                
                const blockData = {
                    threat: threatData,
                    validators: this.validators.slice(0, 3),
                    signatures: this.validators.slice(0, 3).map((v, i) => {
                        const msg = `${newIndex}${timestamp}${JSON.stringify(threatData)}${v}`;
                        let hash = 0;
                        for (let j = 0; j < msg.length; j++) {
                            hash = ((hash << 5) - hash) + msg.charCodeAt(j);
                            hash = hash & hash;
                        }
                        return Math.abs(hash).toString(16).substring(0, 16);
                    }),
                    merkleRoot: this.computeMerkleRoot(threatData)
                };
                
                const newBlock = new Block(newIndex, timestamp, blockData, lastBlock.hash);
                this.chain.push(newBlock);
                
                const activity = {
                    content: threatData.content?.substring(0, 50) || 'New threat',
                    type: threatData.type,
                    time: new Date().toLocaleTimeString()
                };
                addRecentActivity(activity);
                
                return newBlock;
            }

            computeMerkleRoot(data) {
                const str = JSON.stringify(data);
                let hash = 0;
                for (let i = 0; i < str.length; i++) {
                    hash = ((hash << 5) - hash) + str.charCodeAt(i);
                    hash = hash & hash;
                }
                return Math.abs(hash).toString(16).substring(0, 16);
            }

            getLedger(limit = 30) {
                return this.chain.slice(-limit);
            }

            verifyChain() {
                for (let i = 1; i < this.chain.length; i++) {
                    if (this.chain[i].previousHash !== this.chain[i-1].hash) return false;
                    if (this.chain[i].hash !== this.chain[i].computeHash()) return false;
                }
                return true;
            }

            getStats() {
                let totalRisk = 0;
                const threatTypes = {};
                
                for (let i = 1; i < this.chain.length; i++) {
                    const threat = this.chain[i].data.threat || {};
                    totalRisk += threat.riskScore || 0;
                    const type = threat.type || 'unknown';
                    threatTypes[type] = (threatTypes[type] || 0) + 1;
                }
                
                const validBlocks = this.chain.length - 1;
                return {
                    total: validBlocks,
                    avgRisk: validBlocks > 0 ? Math.round(totalRisk / validBlocks) : 0,
                    types: threatTypes
                };
            }
        }

        // ======================= NETWORK VISUALIZATION =======================
        class NetworkVisualizer {
            constructor(canvas) {
                this.canvas = canvas;
                this.ctx = canvas.getContext('2d');
                this.nodes = [];
                this.connections = [];
                this.initNodes();
            }

            initNodes() {
                const nodeNames = [
                    {name: 'node-alpha', location: 'US-East'},
                    {name: 'node-beta', location: 'EU-West'},
                    {name: 'node-gamma', location: 'Asia-Pacific'},
                    {name: 'node-delta', location: 'US-West'},
                    {name: 'node-epsilon', location: 'South-America'}
                ];

                const centerX = this.canvas.width / 2;
                const centerY = this.canvas.height / 2;
                const radius = Math.min(centerX, centerY) - 50;

                nodeNames.forEach((n, i) => {
                    const angle = (i / nodeNames.length) * Math.PI * 2;
                    this.nodes.push({
                        x: centerX + Math.cos(angle) * radius,
                        y: centerY + Math.sin(angle) * radius,
                        ...n,
                        status: 'online'
                    });
                });

                for (let i = 0; i < this.nodes.length; i++) {
                    for (let j = i + 1; j < this.nodes.length; j++) {
                        if (Math.random() > 0.5) {
                            this.connections.push([i, j]);
                        }
                    }
                }
            }

            draw() {
                this.ctx.fillStyle = 'rgba(6, 9, 15, 0.3)';
                this.ctx.fillRect(0, 0, this.canvas.width, this.canvas.height);

                this.ctx.strokeStyle = 'rgba(0, 212, 255, 0.2)';
                this.connections.forEach(([i, j]) => {
                    this.ctx.beginPath();
                    this.ctx.moveTo(this.nodes[i].x, this.nodes[i].y);
                    this.ctx.lineTo(this.nodes[j].x, this.nodes[j].y);
                    this.ctx.stroke();
                });

                this.nodes.forEach((node, i) => {
                    const pulse = Math.sin(Date.now() / 500 + i) * 0.3 + 0.7;
                    
                    this.ctx.beginPath();
                    this.ctx.arc(node.x, node.y, 15, 0, Math.PI * 2);
                    this.ctx.fillStyle = `rgba(0, 255, 136, ${pulse})`;
                    this.ctx.fill();

                    this.ctx.beginPath();
                    this.ctx.arc(node.x, node.y, 8, 0, Math.PI * 2);
                    this.ctx.fillStyle = '#00ff88';
                    this.ctx.fill();

                    this.ctx.font = '10px IBM Plex Mono';
                    this.ctx.fillStyle = '#00d4ff';
                    this.ctx.textAlign = 'center';
                    this.ctx.fillText(node.name, node.x, node.y + 30);
                });

                requestAnimationFrame(() => this.draw());
            }
        }

        // ======================= CHART =======================
        class ThreatChart {
            constructor(canvas) {
                this.canvas = canvas;
                this.ctx = canvas.getContext('2d');
                this.data = {phishing: 35, malware: 20, scam: 30, other: 15};
            }

            draw() {
                const { width, height } = this.canvas;
                this.ctx.clearRect(0, 0, width, height);

                const total = Object.values(this.data).reduce((a, b) => a + b, 0);
                let startAngle = -Math.PI / 2;
                const colors = ['#ff3366', '#ffaa00', '#00d4ff', '#00ff88'];
                let i = 0;

                for (const [key, value] of Object.entries(this.data)) {
                    const sliceAngle = (value / total) * Math.PI * 2;
                    
                    this.ctx.beginPath();
                    this.ctx.moveTo(width/2, height/2);
                    this.ctx.arc(width/2, height/2, 80, startAngle, startAngle + sliceAngle);
                    this.ctx.closePath();
                    this.ctx.fillStyle = colors[i % colors.length];
                    this.ctx.fill();
                    
                    startAngle += sliceAngle;
                    i++;
                }

                this.ctx.beginPath();
                this.ctx.arc(width/2, height/2, 40, 0, Math.PI * 2);
                this.ctx.fillStyle = '#0d1219';
                this.ctx.fill();

                this.ctx.font = 'bold 14px Orbitron';
                this.ctx.fillStyle = '#00ff88';
                this.ctx.textAlign = 'center';
                this.ctx.textBaseline = 'middle';
                this.ctx.fillText(total, width/2, height/2);
            }

            update(newData) {
                this.data = newData;
                this.draw();
            }
        }

