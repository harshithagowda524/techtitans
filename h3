        .indicators-section {
            margin-top: 20px;
        }

        .indicators-title {
            font-family: 'Orbitron', sans-serif;
            font-size: 0.85rem;
            color: var(--secondary);
            margin-bottom: 15px;
            letter-spacing: 2px;
